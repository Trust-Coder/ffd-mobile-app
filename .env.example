# Base URL for the FFD public app API (the surface defined in
# backend/0001-public-api-kickoff.md). Pick the form that matches your target:
#
#   Web dev (browser):   http://localhost:8000/api/app/v1
#   Android emulator:     http://10.0.2.2:8000/api/app/v1   (10.0.2.2 = host loopback)
#   Physical device:      http://<your-LAN-ip>:8000/api/app/v1
#   Production:           https://<ffd-host>/api/app/v1
VITE_API_BASE_URL=http://localhost:8000/api/app/v1

# Dev-only: "1" serves fixtures (src/lib/mocks.ts) instead of calling the API,
# so the screens render without a live backend. Production builds ignore it.
# VITE_USE_MOCKS=1
